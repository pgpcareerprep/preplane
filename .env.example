# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Supabase project
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id
VITE_SUPABASE_URL=https://your_supabase_project_id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google OAuth (used for Google Sheets auth and Drive access)
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id

# Gmail OAuth sender (Supabase secrets — not in .env for production)
# GOOGLE_OAUTH_CLIENT_ID=456969846603-xxxx.apps.googleusercontent.com
# Must be the "PrepLane" Web application client — NOT the Compute Engine service-account client.
# GOOGLE_OAUTH_CLIENT_SECRET=web_oauth_client_secret
# Aliases also accepted: GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET
# Optional manual refresh token instead of Connect Gmail UI:
# GMAIL_OAUTH_REFRESH_TOKEN=
# GMAIL_OAUTH_SENDER_EMAIL=pgpcareerprep@mastersunion.org
# Register redirect URI in Google Cloud Console:
# https://preplane.pages.dev/settings/notifications
