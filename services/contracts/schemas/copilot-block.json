{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://preplane.dev/schemas/copilot-block.json",
  "title": "CopilotBlock",
  "description": "Dynamic block types from src/lib/copilotBlocks.ts VALID_BLOCK_TYPES allowlist.",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
