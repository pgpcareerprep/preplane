{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://preplane.dev/schemas/command-envelope.json",
  "title": "CommandEnvelope",
  "description": "The only wire shape that may trigger a deterministic write.",
  "type": "object",
  "required": [
    "command",
    "entityId",
    "payload",
    "idempotencyKey",
    "requestedBy",
    "issuedAt"
  ],
  "additionalProperties": false,
  "properties": {
    "command": {
      "type": "string",
      "enum": [
        "ADD_LMP_RECORD",
        "UPDATE_LMP_STATUS",
        "UPDATE_LMP_FIELD",
        "ASSIGN_POC",
        "DELETE_LMP_RECORD",
        "BULK_UPDATE",
        "LOG_SUBMISSION"
      ]
    },
    "entityId": { "type": "string" },
    "payload": { "type": "object", "additionalProperties": true },
    "idempotencyKey": { "type": "string", "minLength": 8 },
    "requestedBy": { "type": "string" },
    "issuedAt": { "type": "string", "format": "date-time" },
    "currentSnapshot": { "type": ["object", "null"], "additionalProperties": true },
    "proposedSnapshot": { "type": ["object", "null"], "additionalProperties": true }
  }
}
