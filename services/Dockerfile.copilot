# syntax=docker/dockerfile:1
# Production image for Render: intent-router + gateway in one web service.
# rand 0.10+ needs edition2024 support (Cargo 1.85+).
ARG RUST_VERSION=1.96
FROM rust:${RUST_VERSION}-bookworm AS builder
WORKDIR /app
COPY Cargo.toml Cargo.lock ./
COPY contracts/rust/preplane-contracts ./contracts/rust/preplane-contracts
COPY shared/rust-health ./shared/rust-health
COPY governance ./governance
COPY gateway ./gateway
COPY intent-router ./intent-router
COPY query-path ./query-path
COPY command-path ./command-path
COPY command-plane ./command-plane
COPY event-bus ./event-bus
COPY engines ./engines
RUN cargo build --release -p preplane-gateway -p preplane-intent-router

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=builder /app/target/release/preplane-intent-router /usr/local/bin/preplane-intent-router
COPY --from=builder /app/target/release/preplane-gateway /usr/local/bin/preplane-gateway
COPY deploy/start.sh /usr/local/bin/start.sh
RUN chmod +x /usr/local/bin/start.sh
ENV INTENT_ROUTER_PORT=8081
EXPOSE 8080
CMD ["/usr/local/bin/start.sh"]
